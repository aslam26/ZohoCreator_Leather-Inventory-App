		workflow
		{
		form
		{
			Completed_Lot as "Completed Lot"
			{
				type =  form
				form = LOT_MASTER

				record event = on edit

				on user input of Status
				{
					actions 
					{
						custom deluge script
						(
											input.Total_Chemical_Used.clear();
										input.Total_Raw_Material_Used.clear();
										if(input.Status == "Completed")
										{
											drums = DRUM_DETAILS[LOT_Number == input.ID];
											//inserting chemical used in Lot Master 
											//rowList = List();
											chemList = List();
											for each  d in drums
											{
												for each  c in d.Chemicals
												{
													chemList.add(c.Chemical_Master);
												}
											}
											chemList = chemList.distinct();
											for each  chem in chemList
											{
												total_Qty = 0;
												for each  d in drums
												{
													for each  c in d.Chemicals
													{
														if(c.Chemical_Master == chem)
														{
															total_Qty = total_Qty + c.Calculated_Qty;
															chemName = c.Chemical_Master;
														}
													}
												}
												row1 = LOT_MASTER.Total_Chemical_Used();
												row1.Chemical_Summary=chem;
												row1.Total_Qty_Kg=total_Qty;
												input.Total_Chemical_Used.insert(row1);
											}
											//Insert raw material used in lot master
											rawList = List();
											for each  d in drums
											{
												for each  r in d.Raw_Materials
												{
													rawList.add(r.Raw_Material);
												}
											}
											//info "raw list:" + rawList;
											rawList = rawList.distinct();
											for each  raw in rawList
											{
												total_weight = 0;
												pieces = 0;
												for each  d in drums
												{
													for each  r in d.Raw_Materials
													{
														if(r.Raw_Material == raw)
														{
															total_weight = total_weight + r.Weight;
															rawName = r.Raw_Material;
															pieces = pieces + r.Pieces;
														}
													}
												}
												row2 = LOT_MASTER.Total_Raw_Material_Used();
												row2.Raw_Material=rawName;
												row2.Total_Weight=total_weight;
												row2.PCS=pieces;
												input.Total_Raw_Material_Used.insert(row2);
											}
											// update the total output
											//1 KG = 2.2 SQFT
											input.Total_Output = input.Total_Raw_Material_Used.Total_Weight * 2.2;
										}
						)
					}
				}

			}
			Calculated_the_Qty as "Calculated the Qty"
			{
				type =  form
				form = DRUM_DETAILS

				record event = on add or edit

				on user input of Chemicals.Percentage
				{
					actions 
					{
						custom deluge script
						(
											row.Calculated_Qty=(row.Percentage * input.Raw_Materials.Weight) / 100;
						)
					}
				}

			}
			Item_Id_From_Inventory as "Item Id From Inventory"
			{
				type =  form
				form = Chemical_Master

				record event = on add or edit

				on user input of Chemical
				{
					actions 
					{
						custom deluge script
						(
											listOfItems = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/items?organization_id=" + input.orgid_cache
											type :GET
											connection:"zoho_inventory_connection"
										];
										items = listOfItems.get("items");
										for each  item in items
										{
											if(input.Chemical == item.get("item_name"))
											{
												input.Item_Id = item.get("item_id");
												break;
											}
										}
						)
					}
				}

			}
			Updating_Inventory as "Updating Inventory"
			{
				type =  form
				form = LOT_MASTER

				record event = on edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											organisation_response = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/organizations"
											type :GET
											connection:"zoho_inventory_connection"
										];
										orgId = organisation_response.get("organizations").get(0).get("organization_id");
										if(input.Status == "Completed" && input.Total_Output != null)
										{
											line_item = List();
											productId = input.Product_Name.Product_ID;
											productName = input.Product_Name;
											itemQuantity = input.Total_Output;
											itemMap = Map();
											itemMap.put("item_id",productId);
											itemMap.put("name",productName);
											itemMap.put("quantity_adjusted",itemQuantity);
											line_item.add(itemMap);
											for each  chem in input.Total_Chemical_Used
											{
												chemMap = Map();
												chemMap.put("item_id",chem.Chemical_Summary.Item_Id);
												chemMap.put("name",chem.Chemical_Summary.Chemical);
												deduction_value = 0 - chem.Total_Qty_Kg;
												chemMap.put("quantity_adjusted",deduction_value);
												line_item.add(chemMap);
											}
											for each  raw in input.Total_Raw_Material_Used
											{
												rawMap = Map();
												rawMap.put("item_id",raw.Raw_Material.Raw_Material_Id);
												rawMap.put("name",raw.Raw_Material);
												deduction_value_raw = 0 - raw.Total_Weight;
												rawMap.put("quantity_adjusted",deduction_value_raw);
												line_item.add(rawMap);
											}
											paraMap = Map();
											paraMap.put("date",zoho.currentdate.toString("yyyy-MM-dd"));
											paraMap.put("reason","new lot");
											paraMap.put("adjustment_type","quantity");
											paraMap.put("line_items",line_item);
											response = invokeurl
											[
												url :"https://www.zohoapis.in/inventory/v1/inventoryadjustments?organization_id=" + orgId
												type :POST
												parameters:paraMap.toString()
												headers:{"Content-Type":"application/json"}
												connection:"zoho_inventory_connection"
											];
										}
						)
					}
				}

			}
			Chemical_Name_from_Invent as "Chemical Name from Inventory"
			{
				type =  form
				form = Chemical_Master

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											organisation_response = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/organizations"
											type :GET
											connection:"zoho_inventory_connection"
										];
										orgId = organisation_response.get("organizations").get(0).get("organization_id");
										input.orgid_cache = orgId;
										listOfItems = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/items?organization_id=" + orgId
											type :GET
											connection:"zoho_inventory_connection"
										];
										itemList = listOfItems.get("items");
										clear Chemical;
										for each  item in itemList
										{
											categoryName = item.get("cf_category");
											if(categoryName == "CHEMICAL")
											{
												input.Chemical:ui.add(item.get("item_name"));
											}
										}
						)
					}
				}

			}
