			Products as "Products"
			{
				type =  form
				form = Product

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											organization_response = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/organizations"
											type :GET
											connection:"zoho_inventory_connection"
										];
										orgId = organization_response.get("organizations").get(0).get("organization_id");
										input.orgcache = orgId;
										productList = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/items?organization_id=" + orgId
											type :GET
											connection:"zoho_inventory_connection"
										];
										prodList = productList.get("items");
										clear Product_Name;
										for each  prod in prodList
										{
											categoryName = prod.get("cf_category");
											if(categoryName == "END PRODUCT")
											{
												input.Product_Name:ui.add(prod.get("item_name"));
											}
										}
						)
					}
				}

			}
			Send_Email_Form_Propertie as "Send Email - Form Properties"
			{
				type =  presuccess
				form = LOT_MASTER
					status = inactive
				on start
				{
					actions 
					{
						sendmail
						(
							from : "zoho.adminuserid"
							to : "zoho.adminuserid"
							subject : "Leather Manufacturing ERP for SME : New entry added"
							message : "Hello,<br/><br/>A new entry added in 'LOT MASTER' form of 'Leather Manufacturing ERP for SME' application.<br/><br><br><br><br>"
							attachments : template : _default as inline
						)
					}
				}
			}
			Product_ID as "Product ID"
			{
				type =  form
				form = Product

				record event = on add or edit

				on user input of Product_Name
				{
					actions 
					{
						custom deluge script
						(
											productList = invokeurl
										[
											url :"https://www.zohoapis.in/inventory/v1/items?organization_id=" + input.orgcache
											type :GET
											connection:"zoho_inventory_connection"
										];
										listOfProduct = productList.get("items");
										for each  prod in listOfProduct
										{
											if(input.Product_Name == prod.get("item_name"))
											{
												input.Product_ID = prod.get("item_id");
												break;
											}
										}
						)
					}
				}

			}
		}






